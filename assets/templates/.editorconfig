# EditorConfig 配置文件规范文档: http://editorconfig.org

# 声明这是最顶层的配置文件, 告诉编辑器不要再向上级目录查找其他 .editorconfig
root = true

# ==========================================
# 全局默认规则 (匹配所有文件)
# ==========================================
[*]
# 统一使用 utf-8 编码
charset = utf-8
# 使用空格进行缩进
indent_style = space
# 默认缩进大小为 4 个空格
indent_size = 4
# 统一换行符为 LF (Unix/macOS/Linux 标准)
end_of_line = lf
# 保存时确保文件末尾自动添加一个空行 (符合 POSIX 标准)
insert_final_newline = true
# 保存时自动删除行尾的多余空格
trim_trailing_whitespace = true
# 不限制最大行宽（0 通常表示关闭行宽检查）
max_line_length = 0

# ==========================================
# 针对特定文件类型的覆盖规则
# ==========================================

# 匹配前端及相关配置文件 (JS/TS/CSS/Vue/YAML等)
[*.{js,jsx,ts,tsx,json,css,scss,less,html,vue,yml,yaml}]
indent_size = 2
indent_style = space

[*.go]
# WARNING: Go 语言官方规范强制/推荐使用 tab 缩进
indent_style = tab

[Makefile]
# WARNING: Makefile 语法严格要求命令前必须使用 tab 缩进, 使用空格会导致运行报错
indent_style = tab
# 将 tab 的显示宽度设置为 2
indent_size = 2

[*.md]
# 缩进显示为 3 个空格
indent_size = 3
# WARNING: 禁用自动删除行尾空格, Markdown 中行尾打两个空格代表"强制换行"
trim_trailing_whitespace = false

[*.tex]
indent_size = 2

[*.lua]
indent_size = 2

