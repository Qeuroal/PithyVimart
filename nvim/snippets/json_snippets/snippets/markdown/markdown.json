{
  "YAML Title": {
    "prefix": "yamltitle",
    "body": [
      "---",
      "title: ${1}",
      "description: ${2:omit...}",
      "date: ${3:$CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE $CURRENT_HOUR:$CURRENT_MINUTE:$CURRENT_SECOND}",
      "categories:",
      "- ${4}",
      "tags:",
      "- ${5}",
      "toc: ${6:true}",
      "mathjax: ${7:true}",
      "---",
      "",
      "${0}"
    ],
    "description": "YAML Front Matter Title"
  },
  "Paper format arrangement": {
    "prefix": "pfa",
    "body": [
      "> ${1:Authors}",
      "> ${2:Journal/conference name}",
      "",
      "- 类别: ${3}",
      "- 中心论点: ${4}",
      "- 动机: ${5}",
      "- 主要贡献: ${6}",
      "- 主要问题: ${7}",
      "",
      "${0}"
    ],
    "description": "Paper Format Arrangement"
  },
  "inmath": {
    "prefix": "inmath",
    "body": [
      "$ ${1} $${0}"
    ],
    "description": "inline math"
  },
  "mathblock": {
    "prefix": "mathblock",
    "body": [
      "$$",
      "$1",
      "$$",
      "",
      "${0}"
    ],
    "description": "math block"
  }
}
